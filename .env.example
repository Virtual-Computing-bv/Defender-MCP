# Microsoft Defender for Endpoint Credentials
# Copy this file to .env and fill in your actual values

# Azure AD / Microsoft Entra ID Application Settings
DEFENDER_TENANT_ID=your-tenant-id-here
DEFENDER_CLIENT_ID=your-client-id-here
DEFENDER_CLIENT_SECRET=your-client-secret-here

# Optional: Override the default API base URL (typically not needed)
# DEFENDER_API_BASE_URL=https://api.securitycenter.microsoft.com
