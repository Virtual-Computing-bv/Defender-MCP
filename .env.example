# Microsoft Defender for Endpoint MCP — environment variables

# --- Required ---
DEFENDER_TENANT_ID=00000000-0000-0000-0000-000000000000
DEFENDER_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Provide EITHER cert (preferred) OR client secret:
# Cert mode — DEFENDER_CERT_KEY_PATH must point at a PEM-encoded private key
# that the container can read; DEFENDER_CERT_THUMBPRINT is the SHA-1 fingerprint
# shown in Entra under "Certificates & secrets".
# DEFENDER_CERT_THUMBPRINT=AABBCCDDEEFF11223344556677889900AABBCCDD
# DEFENDER_CERT_KEY_PATH=/run/secrets/defender_cert_key.pem
#
# Secret mode — leaves a plaintext secret in env; rotate every 90 days max.
DEFENDER_CLIENT_SECRET=your-client-secret-here

# --- Optional ---
# Pick the region for your tenant. Defaults to "global"; VC uses "eu".
# DEFENDER_REGION=eu

# Or override the bases directly (e.g. for sovereign clouds or testing):
# DEFENDER_MTP_BASE_URL=https://eu.api.security.microsoft.com/api
# DEFENDER_WDATP_BASE_URL=https://api-eu.securitycenter.microsoft.com/api
